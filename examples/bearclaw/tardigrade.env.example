TARDIGRADE_LISTEN_HOST=0.0.0.0
TARDIGRADE_LISTEN_PORT=443

TARDIGRADE_CONFIG_PATH=examples/bearclaw/tardigrade.conf

TARDIGRADE_TLS_CERT_PATH=/etc/tardigrade/tls/fullchain.pem
TARDIGRADE_TLS_KEY_PATH=/etc/tardigrade/tls/privkey.pem
TARDIGRADE_HTTP2_ENABLED=true
TARDIGRADE_HTTP3_ENABLED=false

TARDIGRADE_UPSTREAM_BASE_URL=http://127.0.0.1:8080
TARDIGRADE_UPSTREAM_CHAT_BASE_URLS=http://127.0.0.1:8080
TARDIGRADE_UPSTREAM_COMMANDS_BASE_URLS=http://127.0.0.1:8080

TARDIGRADE_PROXY_PASS_CHAT=/v1/chat
TARDIGRADE_PROXY_PASS_COMMANDS_PREFIX=

TARDIGRADE_AUTH_TOKEN_HASHES=521bc8ca01307d0189b55a19da738e39c7204f7077e0076e803026e32b2f9383
TARDIGRADE_JWT_SECRET=replace-me
TARDIGRADE_JWT_ISSUER=bearclaw
TARDIGRADE_JWT_AUDIENCE=bearclaw-api

TARDIGRADE_SESSION_STORE_PATH=/var/lib/tardigrade/sessions.json
TARDIGRADE_SESSION_TTL_SECONDS=3600
TARDIGRADE_DEVICE_AUTH_REQUIRED=true
TARDIGRADE_DEVICE_REGISTRY_PATH=/var/lib/tardigrade/devices.json

TARDIGRADE_POLICY_RULES=POST|^/v1/commands$|commands.execute|false||
TARDIGRADE_POLICY_USER_SCOPES=operator:commands.execute,approvals.respond
TARDIGRADE_POLICY_APPROVAL_ROUTES=POST|^/v1/commands$

TARDIGRADE_APPROVAL_STORE_PATH=/var/lib/tardigrade/approvals.json
TARDIGRADE_APPROVAL_TTL_MS=1800000
TARDIGRADE_APPROVAL_MAX_PENDING_PER_IDENTITY=10
TARDIGRADE_TRANSCRIPT_STORE_PATH=/var/lib/tardigrade/transcripts.ndjson

TARDIGRADE_WEBSOCKET_ENABLED=true
TARDIGRADE_SSE_ENABLED=true
TARDIGRADE_MUX_MAX_CHANNELS_PER_DEVICE=32
TARDIGRADE_MUX_WRITE_BUFFER_MAX=131072
TARDIGRADE_MUX_RECONNECT_GRACE_MS=30000

TARDIGRADE_PROXY_CACHE_TTL_SECONDS=0
TARDIGRADE_ACCESS_LOG_FORMAT=json
TARDIGRADE_ERROR_LOG_PATH=stderr
