# BearClaw edge example — production knobs and recommended defaults.
# Public edge: TLS on :443.
# Private app: BearClaw stays on loopback HTTP, reached through Tardigrade.
#
# Copy this file to the location referenced by your systemd EnvironmentFile=
# directive and fill in the secrets. Never commit the live copy.

# ── Network ───────────────────────────────────────────────────────────────────

TARDIGRADE_LISTEN_HOST=0.0.0.0
TARDIGRADE_LISTEN_PORT=443

# ── TLS ───────────────────────────────────────────────────────────────────────

# Replace with your real certificate and private key paths.
TARDIGRADE_TLS_CERT_PATH=/etc/tardigrade/tls/fullchain.pem
TARDIGRADE_TLS_KEY_PATH=/etc/tardigrade/tls/privkey.pem
TARDIGRADE_HTTP2_ENABLED=true
TARDIGRADE_HTTP3_ENABLED=false
# HTTP/3 requires a dedicated QUIC port when enabled.
# TARDIGRADE_QUIC_PORT=443

# ── Config file ───────────────────────────────────────────────────────────────

# Location blocks, routing rules, and per-location auth directives live here.
# See examples/bearclaw/tardigrade.conf for the full shape.
TARDIGRADE_CONFIG_PATH=/etc/tardigrade/tardigrade.conf

# ── Upstreams ─────────────────────────────────────────────────────────────────

# BearClaw upstreams stay private on loopback HTTP.
TARDIGRADE_UPSTREAM_BASE_URL=http://127.0.0.1:8080
TARDIGRADE_UPSTREAM_CHAT_BASE_URLS=http://127.0.0.1:8080
TARDIGRADE_UPSTREAM_COMMANDS_BASE_URLS=http://127.0.0.1:8080

# Proxy timeout: how long Tardigrade waits for a response from the upstream.
TARDIGRADE_UPSTREAM_TIMEOUT_MS=30000

# Passive health: mark a backend unhealthy after this many consecutive failures.
TARDIGRADE_UPSTREAM_MAX_FAILS=3
TARDIGRADE_UPSTREAM_FAIL_TIMEOUT_MS=30000

# Active health probe: Tardigrade probes this path every interval.
TARDIGRADE_UPSTREAM_ACTIVE_PROBE_PATH=/health
TARDIGRADE_UPSTREAM_ACTIVE_PROBE_INTERVAL_MS=10000
TARDIGRADE_UPSTREAM_ACTIVE_PROBE_TIMEOUT_MS=5000

# Legacy per-role upstream shortcuts (still respected when set).
TARDIGRADE_PROXY_PASS_CHAT=/v1/chat
TARDIGRADE_PROXY_PASS_COMMANDS_PREFIX=

# ── Auth ──────────────────────────────────────────────────────────────────────

# Store lowercase SHA-256 hashes of raw bearer tokens here, never the raw token.
# macOS / BSD: printf '%s' "$TOKEN" | shasum -a 256 | awk '{print $1}'
# Linux:       printf '%s' "$TOKEN" | sha256sum | awk '{print $1}'
# Multiple tokens: comma-separated list of hashes.
TARDIGRADE_AUTH_TOKEN_HASHES=replace-me-with-sha256-hash-of-bearer-token

# HMAC secret used for upstream trust headers and per-location sticky affinity
# cookies when multiple backends are configured for a relative proxy target.
# Generate with: openssl rand -hex 32
TARDIGRADE_TRUST_SHARED_SECRET=replace-me

# JWT auth for BearClawWeb. Must match the secret used when signing tokens.
# Generate with: openssl rand -hex 32
TARDIGRADE_JWT_SECRET=replace-me
TARDIGRADE_JWT_ISSUER=bearclaw
TARDIGRADE_JWT_AUDIENCE=bearclaw-api

# Per-location auth directives live in tardigrade.conf (auth required / auth off).
# Inbound X-Tardigrade-* headers from clients are always stripped before the
# auth pipeline runs — clients cannot forge asserted identity headers.

# ── Sessions ──────────────────────────────────────────────────────────────────

# Tardigrade manages this JSON session store itself.
# Keep it owned by the service account (chmod 600) and outside the web root.
TARDIGRADE_SESSION_STORE_PATH=/var/lib/tardigrade/sessions.json
# Idle session TTL in seconds. 3600 = 1 hour.
TARDIGRADE_SESSION_TTL_SECONDS=3600
# Maximum concurrent live sessions (oldest evicted when limit is reached).
TARDIGRADE_SESSION_MAX=10000

# ── Device registry ───────────────────────────────────────────────────────────

# Line-oriented registry: one `device_id|public_key` entry per line.
# Treat like a credential file — owned by the service account, chmod 600.
TARDIGRADE_DEVICE_REGISTRY_PATH=/var/lib/tardigrade/devices.registry
TARDIGRADE_DEVICE_AUTH_REQUIRED=true

# ── Rate limiting ─────────────────────────────────────────────────────────────

# Token-bucket rate limiter keyed on asserted identity (JWT/bearer), IP fallback.
# Set to 0 to disable. Recommended production starting point: 60/10.
TARDIGRADE_RATE_LIMIT_RPS=60
TARDIGRADE_RATE_LIMIT_BURST=10

# ── Transcripts ───────────────────────────────────────────────────────────────

# Append-only NDJSON transcript log. Raw bearer tokens and JWTs are redacted
# before write, but the file contains operator payloads — keep outside web root,
# owned by service account, chmod 600.
TARDIGRADE_TRANSCRIPT_STORE_PATH=/var/lib/tardigrade/transcripts.ndjson

# ── Policy / approvals ────────────────────────────────────────────────────────

TARDIGRADE_POLICY_RULES=POST|^/v1/commands$|commands.execute|false||
TARDIGRADE_POLICY_USER_SCOPES=operator:commands.execute,approvals.respond
TARDIGRADE_POLICY_APPROVAL_ROUTES=POST|^/v1/commands$

# Approval state is persisted as Tardigrade-managed JSON.
TARDIGRADE_APPROVAL_STORE_PATH=/var/lib/tardigrade/approvals.json
# Approval TTL in milliseconds. 1800000 = 30 minutes.
TARDIGRADE_APPROVAL_TTL_MS=1800000
TARDIGRADE_APPROVAL_MAX_PENDING_PER_IDENTITY=10

# ── Real-time ─────────────────────────────────────────────────────────────────

TARDIGRADE_WEBSOCKET_ENABLED=true
TARDIGRADE_SSE_ENABLED=true
TARDIGRADE_MUX_MAX_CHANNELS_PER_DEVICE=32
TARDIGRADE_MUX_WRITE_BUFFER_MAX=131072
TARDIGRADE_MUX_RECONNECT_GRACE_MS=30000

# ── Request limits ────────────────────────────────────────────────────────────

# Maximum request body size in bytes. 0 = unlimited (not recommended).
TARDIGRADE_MAX_BODY_SIZE=10485760

# ── Security headers ──────────────────────────────────────────────────────────

# Comma-separated list of headers Tardigrade adds to every response.
# Adjust CSP and HSTS max-age to match your deployment.
TARDIGRADE_SECURITY_HEADERS=Strict-Transport-Security: max-age=63072000; includeSubDomains,X-Content-Type-Options: nosniff,X-Frame-Options: DENY

# ── Caching ───────────────────────────────────────────────────────────────────

# 0 = no proxy-layer caching (recommended for authenticated API traffic).
TARDIGRADE_PROXY_CACHE_TTL_SECONDS=0

# ── Logging ───────────────────────────────────────────────────────────────────

TARDIGRADE_LOG_LEVEL=info
TARDIGRADE_ACCESS_LOG_FORMAT=json
TARDIGRADE_ERROR_LOG_PATH=stderr
