<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>io.barelabs.tardigrade</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/tardigrade</string>
        <string>run</string>
        <string>-c</string>
        <string>/usr/local/etc/tardigrade/tardigrade.conf</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <key>TARDIGRADE_CONFIG_PATH</key>
        <string>/usr/local/etc/tardigrade/tardigrade.conf</string>
    </dict>

    <key>KeepAlive</key>
    <true/>

    <key>RunAtLoad</key>
    <true/>

    <key>WorkingDirectory</key>
    <string>/usr/local/var/tardigrade</string>

    <key>StandardOutPath</key>
    <string>/usr/local/var/log/tardigrade/stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/usr/local/var/log/tardigrade/stderr.log</string>
</dict>
</plist>
